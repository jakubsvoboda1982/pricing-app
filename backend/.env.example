# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pricing_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
DEBUG=true
APP_NAME=Pricing Management Software
APP_VERSION=0.1.0

# Email (SMTP - SendGrid or any SMTP provider)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your-sendgrid-api-key-here
SMTP_FROM_EMAIL=noreply@jacobsvoboda.cz
FRONTEND_URL=http://localhost:3000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://pricing.jacobsvoboda.cz
